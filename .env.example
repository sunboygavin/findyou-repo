# Environment Variables for Findyou
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ─── Security (MUST CHANGE IN PRODUCTION) ──────────────────
SECRET_KEY=change-me-to-random-64-char-string
JWT_SECRET=change-me-to-another-random-64-char-string
JWT_EXPIRY_HOURS=24

# ─── Database ──────────────────────────────────────────────
# Default: SQLite (auto-created)
# DATABASE_URL=postgresql://user:pass@localhost:5432/findyou

# ─── DeepSeek AI ───────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ─── Email Notifications ──────────────────────────────────
SMTP_HOST=smtp.126.com
SMTP_PORT=465
SMTP_USER=your@126.com
SMTP_PASS=your-smtp-auth-code
NOTIFY_EMAIL=notify@example.com

# ─── Rate Limiting ─────────────────────────────────────────
CHAT_RATE_LIMIT=30
REGISTER_RATE_LIMIT=5

# ─── Admin Users (comma-separated) ────────────────────────
ADMIN_USERS=admin
